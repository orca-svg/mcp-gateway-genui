{
  "name": "@mcp-gen-ui/mcp-server",
  "version": "0.2.0",
  "description": "stdio MCP server exposing mcp-gen-ui public-benefit discovery tools.",
  "license": "Apache-2.0",
  "author": "Team KOI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orca-svg/mcp-gateway-genui.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/orca-svg/mcp-gateway-genui#readme",
  "bugs": {
    "url": "https://github.com/orca-svg/mcp-gateway-genui/issues"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "bin": {
    "mcp-gen-ui-gateway": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@mcp-gen-ui/adapters": "workspace:*",
    "@mcp-gen-ui/core": "workspace:*",
    "@mcp-gen-ui/schema": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
