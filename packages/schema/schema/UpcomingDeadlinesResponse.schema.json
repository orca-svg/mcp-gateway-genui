{
  "$ref": "#/definitions/UpcomingDeadlinesResponse",
  "definitions": {
    "UpcomingDeadlinesResponse": {
      "type": "object",
      "properties": {
        "profile": {
          "type": "object",
          "properties": {
            "region": {
              "type": "string",
              "minLength": 1
            },
            "ageRange": {
              "type": "string",
              "enum": [
                "teen",
                "twenties",
                "thirties",
                "forties",
                "fifties",
                "sixties_plus"
              ]
            },
            "studentStatus": {
              "type": "string",
              "enum": [
                "student",
                "not_student",
                "unknown"
              ],
              "default": "unknown"
            },
            "employmentStatus": {
              "type": "string",
              "enum": [
                "employed",
                "self_employed",
                "unemployed",
                "unknown"
              ],
              "default": "unknown"
            },
            "householdType": {
              "type": "string",
              "enum": [
                "single",
                "couple",
                "family",
                "single_parent",
                "unknown"
              ],
              "default": "unknown"
            },
            "interests": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "housing",
                  "education",
                  "employment",
                  "health",
                  "family",
                  "youth",
                  "local",
                  "other"
                ]
              },
              "default": []
            },
            "persona": {
              "type": "string",
              "enum": [
                "youth_jobseeker",
                "university_student",
                "newlywed_family",
                "single_parent",
                "senior",
                "general"
              ]
            }
          },
          "additionalProperties": false
        },
        "withinDays": {
          "type": "integer",
          "minimum": 0
        },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "provider": {
                "type": "string",
                "minLength": 1
              },
              "category": {
                "$ref": "#/definitions/UpcomingDeadlinesResponse/properties/profile/properties/interests/items"
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": [
                  "candidate",
                  "needs_more_info",
                  "not_applicable"
                ]
              },
              "score": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "default": 0
              },
              "scoreBreakdown": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "dimension": {
                      "type": "string",
                      "enum": [
                        "region",
                        "age",
                        "student",
                        "employment",
                        "household",
                        "category",
                        "query"
                      ]
                    },
                    "signal": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "weight": {
                      "type": "number",
                      "minimum": 0
                    },
                    "contribution": {
                      "type": "number",
                      "minimum": 0
                    },
                    "explanation": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "dimension",
                    "signal",
                    "weight",
                    "contribution",
                    "explanation"
                  ],
                  "additionalProperties": false
                },
                "default": []
              },
              "reasons": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "missingInfo": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "applicationDeadline": {
                "type": "string",
                "format": "date-time"
              }
            },
            "required": [
              "id",
              "title",
              "provider",
              "category",
              "summary",
              "status",
              "applicationDeadline"
            ],
            "additionalProperties": false
          }
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "profile",
        "results",
        "generatedAt"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
