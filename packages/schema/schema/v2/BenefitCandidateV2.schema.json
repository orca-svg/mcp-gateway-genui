{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "#/$defs/__schema0"
    },
    "title": {
      "type": "string",
      "format": "normalized-display-text",
      "minLength": 1,
      "maxLength": 200
    },
    "provider": {
      "type": "string",
      "format": "normalized-display-text",
      "minLength": 1,
      "maxLength": 160
    },
    "category": {
      "type": "string",
      "enum": [
        "housing",
        "education",
        "employment",
        "health",
        "family",
        "youth",
        "local",
        "other"
      ]
    },
    "summary": {
      "type": "string",
      "format": "normalized-display-text",
      "minLength": 1,
      "maxLength": 2000
    },
    "assessment": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "candidate",
            "needs_more_info",
            "conflict_detected"
          ]
        },
        "constraints": {
          "maxItems": 32,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema1"
          }
        },
        "missingInfo": {
          "maxItems": 32,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema6"
          }
        }
      },
      "required": [
        "status",
        "constraints",
        "missingInfo"
      ],
      "additionalProperties": false
    },
    "ranking": {
      "type": "object",
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "breakdown": {
          "maxItems": 32,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema7"
          }
        }
      },
      "required": [
        "score",
        "breakdown"
      ],
      "additionalProperties": false
    },
    "provenance": {
      "minItems": 1,
      "maxItems": 256,
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema8"
      }
    },
    "links": {
      "minItems": 1,
      "maxItems": 16,
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema10"
      }
    },
    "freshness": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "fresh",
            "stale",
            "unknown"
          ]
        },
        "observedAt": {
          "$ref": "#/$defs/__schema9"
        },
        "staleAfter": {
          "$ref": "#/$defs/__schema9"
        }
      },
      "required": [
        "status",
        "observedAt"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "id",
    "title",
    "provider",
    "category",
    "summary",
    "assessment",
    "ranking",
    "provenance",
    "links",
    "freshness"
  ],
  "additionalProperties": false,
  "$defs": {
    "__schema0": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9:_-]{0,127}$"
    },
    "__schema1": {
      "type": "object",
      "properties": {
        "dimension": {
          "$ref": "#/$defs/__schema2"
        },
        "outcome": {
          "type": "string",
          "enum": [
            "match",
            "conflict",
            "unknown"
          ]
        },
        "basis": {
          "$ref": "#/$defs/__schema3"
        },
        "ruleId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "ruleVersion": {
          "$ref": "#/$defs/__schema4"
        },
        "sourceFields": {
          "maxItems": 32,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema5"
          }
        },
        "explanation": {
          "type": "string",
          "format": "normalized-display-text",
          "minLength": 1,
          "maxLength": 1000
        }
      },
      "required": [
        "dimension",
        "outcome",
        "basis",
        "ruleId",
        "ruleVersion",
        "sourceFields",
        "explanation"
      ],
      "additionalProperties": false
    },
    "__schema2": {
      "type": "string",
      "enum": [
        "region",
        "age",
        "student",
        "employment",
        "household",
        "category",
        "query"
      ]
    },
    "__schema3": {
      "type": "string",
      "enum": [
        "authoritative_structured",
        "derived_text",
        "default"
      ]
    },
    "__schema4": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]*$"
    },
    "__schema5": {
      "type": "string",
      "format": "normalized-display-text",
      "minLength": 1,
      "maxLength": 128
    },
    "__schema6": {
      "type": "string",
      "format": "normalized-display-text",
      "minLength": 1,
      "maxLength": 300
    },
    "__schema7": {
      "type": "object",
      "properties": {
        "dimension": {
          "$ref": "#/$defs/__schema2"
        },
        "signal": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "contribution": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "explanation": {
          "type": "string",
          "format": "normalized-display-text",
          "minLength": 1,
          "maxLength": 1000
        }
      },
      "required": [
        "dimension",
        "signal",
        "weight",
        "contribution",
        "explanation"
      ],
      "additionalProperties": false
    },
    "__schema8": {
      "type": "object",
      "properties": {
        "field": {
          "type": "string",
          "maxLength": 512,
          "pattern": "^(?:\\/(?:[^~/]|~0|~1)*)*$"
        },
        "sourceId": {
          "$ref": "#/$defs/__schema0"
        },
        "sourceRecordId": {
          "type": "string",
          "format": "normalized-display-text",
          "minLength": 1,
          "maxLength": 256
        },
        "authority": {
          "$ref": "#/$defs/__schema3"
        },
        "contentHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "observedAt": {
          "$ref": "#/$defs/__schema9"
        },
        "sourceRevision": {
          "$ref": "#/$defs/__schema4"
        },
        "license": {
          "type": "string",
          "format": "normalized-display-text",
          "minLength": 1,
          "maxLength": 300
        },
        "attribution": {
          "type": "string",
          "format": "normalized-display-text",
          "minLength": 1,
          "maxLength": 300
        }
      },
      "required": [
        "field",
        "sourceId",
        "sourceRecordId",
        "authority",
        "contentHash",
        "observedAt"
      ],
      "additionalProperties": false
    },
    "__schema9": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "__schema10": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "rel": {
              "$ref": "#/$defs/__schema11"
            },
            "health": {
              "$ref": "#/$defs/__schema12"
            },
            "verifiedAt": {
              "$ref": "#/$defs/__schema13"
            },
            "verificationMethod": {
              "$ref": "#/$defs/__schema14"
            },
            "url": {
              "type": "string",
              "maxLength": 2048,
              "format": "safe-https-url"
            },
            "official": {
              "type": "boolean",
              "const": true
            }
          },
          "required": [
            "rel",
            "health",
            "url",
            "official"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "rel": {
              "$ref": "#/$defs/__schema11"
            },
            "health": {
              "$ref": "#/$defs/__schema12"
            },
            "verifiedAt": {
              "$ref": "#/$defs/__schema13"
            },
            "verificationMethod": {
              "$ref": "#/$defs/__schema14"
            },
            "url": {
              "type": "string",
              "maxLength": 2048,
              "format": "safe-public-url"
            },
            "official": {
              "type": "boolean",
              "const": false
            }
          },
          "required": [
            "rel",
            "health",
            "url",
            "official"
          ],
          "additionalProperties": false
        }
      ]
    },
    "__schema11": {
      "type": "string",
      "enum": [
        "source",
        "apply"
      ]
    },
    "__schema12": {
      "type": "string",
      "enum": [
        "verified",
        "stale",
        "unchecked",
        "unreachable"
      ]
    },
    "__schema13": {
      "$ref": "#/$defs/__schema9"
    },
    "__schema14": {
      "type": "string",
      "format": "normalized-display-text",
      "minLength": 1,
      "maxLength": 300
    }
  },
  "$id": "urn:mcp-gen-ui:schema:v2:BenefitCandidateV2"
}
