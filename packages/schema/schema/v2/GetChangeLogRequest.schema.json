{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "entityId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9:_-]{0,127}$"
    },
    "cursor": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "limit": {
      "default": 50,
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    }
  },
  "additionalProperties": false,
  "$id": "urn:mcp-gen-ui:schema:v2:GetChangeLogRequest"
}
