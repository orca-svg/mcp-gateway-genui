{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "benefit-change-log.v2"
    },
    "dataStatus": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "fixture",
            "live",
            "mixed"
          ]
        },
        "partial": {
          "type": "boolean"
        },
        "sources": {
          "minItems": 1,
          "maxItems": 64,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema0"
          }
        }
      },
      "required": [
        "mode",
        "partial",
        "sources"
      ],
      "additionalProperties": false
    },
    "entityId": {
      "$ref": "#/$defs/__schema1"
    },
    "entries": {
      "maxItems": 100,
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema4"
      }
    },
    "nextCursor": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "generatedAt": {
      "$ref": "#/$defs/__schema2"
    }
  },
  "required": [
    "schemaVersion",
    "dataStatus",
    "entries",
    "generatedAt"
  ],
  "additionalProperties": false,
  "$defs": {
    "__schema0": {
      "type": "object",
      "properties": {
        "sourceId": {
          "$ref": "#/$defs/__schema1"
        },
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "partial",
            "timeout",
            "unavailable",
            "invalid_payload"
          ]
        },
        "retrievedAt": {
          "$ref": "#/$defs/__schema2"
        },
        "recordCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        },
        "errorCode": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "adapterVersion": {
          "$ref": "#/$defs/__schema3"
        }
      },
      "required": [
        "sourceId",
        "status",
        "retrievedAt",
        "recordCount",
        "adapterVersion"
      ],
      "additionalProperties": false
    },
    "__schema1": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9:_-]{0,127}$"
    },
    "__schema2": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "__schema3": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]*$"
    },
    "__schema4": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/__schema1"
        },
        "entityId": {
          "$ref": "#/$defs/__schema1"
        },
        "entityType": {
          "type": "string",
          "const": "benefit"
        },
        "changeType": {
          "type": "string",
          "enum": [
            "created",
            "updated",
            "deleted"
          ]
        },
        "changedPaths": {
          "minItems": 1,
          "maxItems": 512,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema5"
          }
        },
        "sourceId": {
          "$ref": "#/$defs/__schema1"
        },
        "sourceRevision": {
          "$ref": "#/$defs/__schema3"
        },
        "contentHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "summary": {
          "type": "string",
          "format": "normalized-display-text",
          "minLength": 1,
          "maxLength": 300
        },
        "createdAt": {
          "$ref": "#/$defs/__schema2"
        }
      },
      "required": [
        "id",
        "entityId",
        "entityType",
        "changeType",
        "changedPaths",
        "sourceId",
        "sourceRevision",
        "contentHash",
        "summary",
        "createdAt"
      ],
      "additionalProperties": false
    },
    "__schema5": {
      "type": "string",
      "maxLength": 512,
      "pattern": "^(?:\\/(?:[^~/]|~0|~1)*)*$"
    }
  },
  "$id": "urn:mcp-gen-ui:schema:v2:GetChangeLogResponse"
}
