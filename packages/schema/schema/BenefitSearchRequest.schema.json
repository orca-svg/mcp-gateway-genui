{
  "$ref": "#/definitions/BenefitSearchRequest",
  "definitions": {
    "BenefitSearchRequest": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "minLength": 1
        },
        "profile": {
          "type": "object",
          "properties": {
            "region": {
              "type": "string",
              "minLength": 1
            },
            "ageRange": {
              "type": "string",
              "enum": [
                "teen",
                "twenties",
                "thirties",
                "forties",
                "fifties",
                "sixties_plus"
              ]
            },
            "studentStatus": {
              "type": "string",
              "enum": [
                "student",
                "not_student",
                "unknown"
              ],
              "default": "unknown"
            },
            "employmentStatus": {
              "type": "string",
              "enum": [
                "employed",
                "self_employed",
                "unemployed",
                "unknown"
              ],
              "default": "unknown"
            },
            "householdType": {
              "type": "string",
              "enum": [
                "single",
                "couple",
                "family",
                "single_parent",
                "unknown"
              ],
              "default": "unknown"
            },
            "interests": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "housing",
                  "education",
                  "employment",
                  "health",
                  "family",
                  "youth",
                  "local",
                  "other"
                ]
              },
              "default": []
            },
            "persona": {
              "type": "string",
              "enum": [
                "youth_jobseeker",
                "university_student",
                "newlywed_family",
                "single_parent",
                "senior",
                "general"
              ]
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "weights": {
          "type": "object",
          "properties": {
            "region": {
              "type": "number",
              "minimum": 0
            },
            "age": {
              "type": "number",
              "minimum": 0
            },
            "student": {
              "type": "number",
              "minimum": 0
            },
            "employment": {
              "type": "number",
              "minimum": 0
            },
            "household": {
              "type": "number",
              "minimum": 0
            },
            "category": {
              "type": "number",
              "minimum": 0
            },
            "query": {
              "type": "number",
              "minimum": 0
            }
          },
          "additionalProperties": false,
          "default": {}
        }
      },
      "required": [
        "query"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
