{
  "$ref": "#/definitions/UpcomingDeadlinesRequest",
  "definitions": {
    "UpcomingDeadlinesRequest": {
      "type": "object",
      "properties": {
        "profile": {
          "type": "object",
          "properties": {
            "region": {
              "type": "string",
              "minLength": 1
            },
            "ageRange": {
              "type": "string",
              "enum": [
                "teen",
                "twenties",
                "thirties",
                "forties",
                "fifties",
                "sixties_plus"
              ]
            },
            "studentStatus": {
              "type": "string",
              "enum": [
                "student",
                "not_student",
                "unknown"
              ],
              "default": "unknown"
            },
            "employmentStatus": {
              "type": "string",
              "enum": [
                "employed",
                "self_employed",
                "unemployed",
                "unknown"
              ],
              "default": "unknown"
            },
            "householdType": {
              "type": "string",
              "enum": [
                "single",
                "couple",
                "family",
                "single_parent",
                "unknown"
              ],
              "default": "unknown"
            },
            "interests": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "housing",
                  "education",
                  "employment",
                  "health",
                  "family",
                  "youth",
                  "local",
                  "other"
                ]
              },
              "default": []
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "withinDays": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
