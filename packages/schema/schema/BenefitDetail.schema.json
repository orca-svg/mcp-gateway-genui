{
  "$ref": "#/definitions/BenefitDetail",
  "definitions": {
    "BenefitDetail": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": [
            "housing",
            "education",
            "employment",
            "health",
            "family",
            "youth",
            "local",
            "other"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "eligibility": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "applicationPeriod": {
          "type": "string"
        },
        "fee": {
          "type": "string"
        },
        "processingTime": {
          "type": "string"
        },
        "documents": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "required": {
                "type": "boolean"
              },
              "source": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "label",
              "required"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "applicationMethods": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "applicationUrl": {
          "type": "string",
          "format": "uri"
        },
        "sourceUrl": {
          "type": "string",
          "format": "uri"
        },
        "lastFetchedAt": {
          "type": "string",
          "format": "date-time"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "field": {
                "type": "string"
              },
              "matched": {
                "type": "boolean"
              },
              "explanation": {
                "type": "string"
              }
            },
            "required": [
              "field",
              "matched",
              "explanation"
            ],
            "additionalProperties": false
          },
          "default": []
        }
      },
      "required": [
        "id",
        "title",
        "provider",
        "category",
        "summary",
        "target",
        "sourceUrl",
        "lastFetchedAt"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
