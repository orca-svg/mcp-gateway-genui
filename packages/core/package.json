{
  "name": "@mcp-gen-ui/core",
  "version": "0.3.0",
  "description": "Transport-neutral public-benefit repository, recommender, and tool service for mcp-gen-ui.",
  "license": "Apache-2.0",
  "author": "Team KOI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orca-svg/mcp-gateway-genui.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/orca-svg/mcp-gateway-genui#readme",
  "bugs": {
    "url": "https://github.com/orca-svg/mcp-gateway-genui/issues"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@mcp-gen-ui/schema": "workspace:*"
  }
}
